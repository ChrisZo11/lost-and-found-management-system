<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <appSettings>
        <add key="PhotoStorageRoot" value="..\..\PhotoStorage" />
    </appSettings>
    <startup>
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>
    <connectionStrings>
        <add name="DbConn" connectionString="Data Source=localhost\SQLEXPRESS;Initial Catalog=LostAndFoundDB;Integrated Security=True;TrustServerCertificate=True" providerName="System.Data.SqlClient" />
    </connectionStrings>
</configuration>
